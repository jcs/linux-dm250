#include <dt-bindings/input/input.h>

 &pinctrl {
	button_pins {
                pwr_key_l: pwr-key-l {
                        rockchip,pins = <0 RK_PA2 RK_FUNC_GPIO &pcfg_pull_none>;
                };
                
                lid_int_l: lid-int-l {
                        rockchip,pins = <0 RK_PC4 RK_FUNC_GPIO &pcfg_pull_none>;
                };

                kbd_rshift_l: kbd-rshift-l {
                        rockchip,pins = <0 RK_PB4 RK_FUNC_GPIO &pcfg_pull_none>;
                };

                kbd_alt_l: kbd-alt-l {
                        rockchip,pins = <0 RK_PB5 RK_FUNC_GPIO &pcfg_pull_none>;
                };
        };

        tc3589x {
		tc3589x_int_l: tc3589x-int-l {
			rockchip,pins = <0 RK_PA7 RK_FUNC_GPIO &pcfg_pull_none>;
		};
                
		tc3589x_reset: tc3589x-reset {
			rockchip,pins = <0 RK_PD1 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};
};

/ {
	gpio-keys {
		compatible = "gpio-keys";
		pinctrl-names = "default";
		pinctrl-0 = <&pwr_key_l &lid_int_l &kbd_rshift_l &kbd_alt_l>;
		/* autorepeat; */
		status = "okay";

		key-power {
			label = "Power Button";
			gpios = <&gpio0 RK_PA2 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_POWER>;
			debounce-interval = <100>;
			wakeup-source;
		};

		switch-lid {
                        label = "Lid Switch";
                        gpios = <&gpio0 RK_PC4 GPIO_ACTIVE_LOW>;
                        linux,code = <SW_LID>;
                        linux,input-type = <EV_SW>;
                        debounce-interval = <100>;
                        wakeup-source;
                };

		// Former Right Shift
                key-forward {
                        label = "Forward";
                        gpios = <&gpio0 RK_PB4 GPIO_ACTIVE_LOW>;
                        linux,code = <KEY_FORWARD>;
                        debounce-interval = <50>;
                        wakeup-source;
                };

                left-alt {
                        label = "Left Alt";
                        gpios = <&gpio0 RK_PB5 GPIO_ACTIVE_LOW>;
                        linux,code = <KEY_LEFTALT>;
                        debounce-interval = <50>;
                        wakeup-source;
                };
	};
};

&i2c0 {
	status = "okay";

	tc3589x@45 {
		compatible = "toshiba,tc35894";
		reg = <0x45>;
		reset-gpios = <&gpio0 RK_PD1 GPIO_ACTIVE_LOW>;
		interrupt-parent = <&gpio0>;
		interrupts = <7 IRQ_TYPE_EDGE_FALLING>;
		pinctrl-names = "default";
		pinctrl-0 = <&tc3589x_int_l &tc3589x_reset>;
		interrupt-controller;
		#interrupt-cells = <1>;
		status = "okay";
		
		tc3589x_keypad {
			compatible = "toshiba,tc3589x-keypad";
			debounce-delay-ms = <50>;
			keypad,num-rows = <8>; /* not counting Fn layer */
			keypad,num-columns = <12>;
			wakeup-source;
			linux,keymap = <
				MATRIX_KEY(0, 0,  KEY_RIGHTALT)
				MATRIX_KEY(0, 3,  KEY_ENTER)
				MATRIX_KEY(0, 4,  KEY_BACKSLASH)
				MATRIX_KEY(0, 5,  KEY_DOT)
				MATRIX_KEY(0, 6,  KEY_COMMA)
				MATRIX_KEY(0, 7,  KEY_M)
				MATRIX_KEY(0, 8,  KEY_V)
				MATRIX_KEY(0, 9,  KEY_C)
				MATRIX_KEY(0, 10, KEY_Z)
				MATRIX_KEY(0, 11, KEY_X)
				/* MATRIX_KEY(1, 0,  KEY_LEFTALT) /\* GPIO0_B5 *\/ */
				MATRIX_KEY(1, 4,  KEY_SEMICOLON)
				MATRIX_KEY(1, 5,  KEY_L)
				MATRIX_KEY(1, 6,  KEY_K)
				MATRIX_KEY(1, 7,  KEY_J)
				MATRIX_KEY(1, 8,  KEY_F)
				MATRIX_KEY(1, 9,  KEY_D)
				MATRIX_KEY(1, 10, KEY_A)
				MATRIX_KEY(1, 11, KEY_S)
				/* MATRIX_KEY(2, 0,  KEY_RIGHTSHIFT) /\* GPIO0_B4 *\/ */
				MATRIX_KEY(2, 3,  KEY_EQUAL) // former YEN
				MATRIX_KEY(2, 4,  KEY_P)
				MATRIX_KEY(2, 5,  KEY_O)
				MATRIX_KEY(2, 6,  KEY_I)
				MATRIX_KEY(2, 7,  KEY_U)
				MATRIX_KEY(2, 8,  KEY_R)
				MATRIX_KEY(2, 9,  KEY_E)
				MATRIX_KEY(2, 10, KEY_Q)
				MATRIX_KEY(2, 11, KEY_W)
				MATRIX_KEY(3, 0,  KEY_RIGHTCTRL)
				MATRIX_KEY(3, 3,  KEY_UNDO) // former F10
				MATRIX_KEY(3, 4,  KEY_9) // former 0
				MATRIX_KEY(3, 5,  KEY_8) // former 9
				MATRIX_KEY(3, 6,  KEY_7) // former 8
				MATRIX_KEY(3, 7,  KEY_6) // former 7
				MATRIX_KEY(3, 8,  KEY_3) // former 4
				MATRIX_KEY(3, 9,  KEY_2) // former 3
				MATRIX_KEY(3, 10, KEY_GRAVE) // former 1
				MATRIX_KEY(3, 11, KEY_1) // former 2
				MATRIX_KEY(4, 0,  KEY_RIGHT)
				MATRIX_KEY(4, 1,  KEY_LEFT)
				MATRIX_KEY(4, 2,  KEY_DOWN)
				MATRIX_KEY(4, 4,  KEY_SLASH)
				MATRIX_KEY(4, 5,  KEY_F11)
				MATRIX_KEY(4, 6,  KEY_BACK) // former RO
				MATRIX_KEY(4, 7,  KEY_N)
				MATRIX_KEY(4, 8,  KEY_F6) // former F5
				MATRIX_KEY(4, 9,  KEY_B)
				MATRIX_KEY(4, 10, KEY_LEFTSHIFT)
				MATRIX_KEY(4, 11, KEY_FN) // former LEFTCTRL
				MATRIX_KEY(5, 3,  KEY_BACKSPACE)
				MATRIX_KEY(5, 4,  KEY_LEFTBRACE)
				MATRIX_KEY(5, 5,  KEY_F8) // former F7
				MATRIX_KEY(5, 6,  KEY_RIGHTBRACE)
				MATRIX_KEY(5, 7,  KEY_Y)
				MATRIX_KEY(5, 8,  KEY_T)
				MATRIX_KEY(5, 9,  KEY_F4) // former F3
				MATRIX_KEY(5, 10, KEY_TAB)
				MATRIX_KEY(5, 11, KEY_LEFTCTRL) // former CAPSLOCK
				MATRIX_KEY(6, 0,  KEY_F12)
				MATRIX_KEY(6, 1,  KEY_UP)
				MATRIX_KEY(6, 2,  KEY_SPACE)
				MATRIX_KEY(6, 4,  KEY_APOSTROPHE)
				MATRIX_KEY(6, 6,  KEY_F7) // former F6
				MATRIX_KEY(6, 7,  KEY_H)
				MATRIX_KEY(6, 8,  KEY_G)
				MATRIX_KEY(6, 9,  KEY_F5) // former F4
				MATRIX_KEY(6, 10, KEY_ESC)
				MATRIX_KEY(6, 11, KEY_LEFTMETA) // former MENU
				MATRIX_KEY(7, 0,  KEY_INSERT)
				MATRIX_KEY(7, 2,  KEY_DELETE)
				MATRIX_KEY(7, 3,  KEY_F10) // former F9
				MATRIX_KEY(7, 4,  KEY_0)  // former MINUS
				MATRIX_KEY(7, 5,  KEY_F9) // former F8
				MATRIX_KEY(7, 6,  KEY_MINUS) // former EQUAL
				MATRIX_KEY(7, 7,  KEY_5) // former 6
				MATRIX_KEY(7, 8,  KEY_4) // former 5
				MATRIX_KEY(7, 9,  KEY_F3) // former F2
				MATRIX_KEY(7, 10, KEY_F1) // former GRAVE
				MATRIX_KEY(7, 11, KEY_F2) // former F1
				/* Fn-modified keys */
				MATRIX_KEY(12, 0,  KEY_END) /* Fn-RIGHT */
				MATRIX_KEY(12, 1,  KEY_HOME) /* Fn-LEFT */
				MATRIX_KEY(12, 2,  KEY_PAGEDOWN) /* Fn-DOWN */
				MATRIX_KEY(12, 11, KEY_FN) /* Fn */
				MATRIX_KEY(13, 9,  KEY_BATTERY) // Fn-F4
				MATRIX_KEY(14, 1,  KEY_PAGEUP) /* Fn-UP */
				MATRIX_KEY(14, 9,  KEY_RFKILL) // Fn-F5
				MATRIX_KEY(15, 9,  KEY_DISPLAY_OFF) // Fn-F3
				MATRIX_KEY(15, 10, KEY_BRIGHTNESSDOWN) // Fn-F1
				MATRIX_KEY(15, 11, KEY_BRIGHTNESSUP) // Fn-F2
			>;
		};
	};

};
